{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sayso",
  "version": "0.1.0",
  "identifier": "com.sayso.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sayso — Preferences",
        "width": 860,
        "height": 640,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "global-shortcut": {},
    "log": {
      "level": "info",
      "targets": [
        {
          "kind": "Stdout"
        },
        {
          "kind": "LogDir",
          "fileName": "sayso.log"
        }
      ]
    }
  }
}
