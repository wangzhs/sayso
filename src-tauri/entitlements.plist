<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Microphone access — required for voice recording via cpal/CoreAudio -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- Outbound network access — required for STT and LLM HTTP API calls -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!--
    Accessibility (CGEvent text injection) is a user-granted permission
    in System Preferences → Security & Privacy → Accessibility.
    It does NOT require an entitlement — macOS will prompt automatically
    the first time Sayso injects keystrokes.
  -->
</dict>
</plist>
